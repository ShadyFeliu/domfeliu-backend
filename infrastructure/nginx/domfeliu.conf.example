# Frontend Configuration
server {
    listen 80;
    server_name domfeliu.com www.domfeliu.com;

    # Redirect all HTTP traffic to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name domfeliu.com www.domfeliu.com;

    # SSL configuration (to be generated by Certbot)
    # ssl_certificate /etc/letsencrypt/live/domfeliu.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/domfeliu.com/privkey.pem;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# API / Backend Configuration
server {
    listen 80;
    server_name api.domfeliu.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name api.domfeliu.com;

    # SSL configuration (to be generated by Certbot)
    # ssl_certificate /etc/letsencrypt/live/api.domfeliu.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.domfeliu.com/privkey.pem;

    location / {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Increase upload size for tracks/images
        client_max_body_size 50M;
    }
}
